{
  "name": "pi-provider-service-tier",
  "version": "0.1.6",
  "description": "Provider/model-scoped service_tier management extension for Pi",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "service-tier",
    "fast"
  ],
  "files": [
    "src/index.ts",
    "presets/*.json",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "check": "npm run typecheck && npm test && npm run pack:dry-run",
    "pack:dry-run": "npm pack --dry-run",
    "test": "node --test --experimental-strip-types src/index.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.75.5",
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "@types/node": "^24.3.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luxmargos/pi-provider-service-tier.git"
  },
  "bugs": {
    "url": "https://github.com/luxmargos/pi-provider-service-tier/issues"
  },
  "homepage": "https://github.com/luxmargos/pi-provider-service-tier#readme",
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "author": {
    "name": "luxmargos",
    "email": "owlflyx12@gmail.com"
  }
}
